<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:OurApp"
             x:Class="OurApp.App"
             UserAppTheme="Unspecified">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="AccentColor">#eccacb</Color>
            <Color x:Key="BlackColor">#3b3b3b</Color>
            <Color x:Key="WhiteColor">#ececec</Color>

            <Style TargetType="Shell">
                <Setter Property="BackgroundColor" Value="{StaticResource BlackColor}" />
                <Setter Property="TitleColor" Value="{StaticResource AccentColor}" />
                <Setter Property="ForegroundColor" Value="{StaticResource AccentColor}" />
                <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource BlackColor}" />
                <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource AccentColor}" />
                <Setter Property="Shell.TabBarUnselectedColor" Value="Gray" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
