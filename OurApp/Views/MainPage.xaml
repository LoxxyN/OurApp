<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OurApp.Views.MainPage"
             Title="КИНО-РУЛЕТКА">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="КИНО-РУЛЕТКА" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#E50914"/>

            <HorizontalStackLayout Spacing="10">
                <Entry x:Name="MovieEntry" Placeholder="Название фильма..." HorizontalOptions="Fill" ReturnType="Done" Completed="OnMovieEntryCompleted"/>
                <Button Text="Добавить" Clicked="OnAddMovieClicked" BackgroundColor="#E50914" WidthRequest="50"/>
            </HorizontalStackLayout>

            <Label x:Name="MoviesCountLabel" Text="Всего фильмов: 0" FontSize="14" TextColor="Gray" HorizontalOptions="End"/>

            <CollectionView x:Name="MoviesCollectionView" HeightRequest="250">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border  Padding="10" Margin="0,5" Stroke="LightGray" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                <Label Text="{Binding .}" VerticalOptions="Center" HorizontalOptions="Fill" FontSize="16"/>
                                <Button Text="V" Clicked="OnMarkWatchedClicked" BackgroundColor="Transparent" TextColor="Green" WidthRequest="40"/>
                                <Button Text="X" Clicked="OnDeleteMovieClicked" BackgroundColor="Transparent" TextColor="Red" WidthRequest="40"/>
                            </HorizontalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button x:Name="SpinButton" Text="Выбрать случайный фильм" Clicked="OnSpinClicked" BackgroundColor="#E50914" FontSize="18" FontAttributes="Bold" CornerRadius="10" HeightRequest="60"/>

            <Border x:Name="ResultFrame" IsVisible="False" BackgroundColor="#2C2C2C" Padding="20" StrokeShape="RoundRectangle 10">
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="Вам выпал:" FontSize="16" TextColor="White" HorizontalOptions="Center"/>
                    <Label x:Name="ResultLabel" FontSize="24" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>

            <HorizontalStackLayout HorizontalOptions="Center">
                <Button x:Name="ClearListButton" Text="🗑 Очистить список" Clicked="OnClearListClicked" BackgroundColor="Gray" IsVisible="False"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
